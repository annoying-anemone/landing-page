{
  "name": "@cigales-cloud/landing-page",
  "version": "0.1.0",
  "description": "AstroWind: A free template using Astro 4.0 and Tailwind CSS. Astro starter theme.",
  "type": "module",
  "engines": {
    "node": "^25.9.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "npm run check:astro && npm run check:eslint && npm run check:prettier",
    "check:astro": "astro check",
    "check:eslint": "eslint .",
    "check:prettier": "prettier --check .",
    "fix": "npm run fix:eslint && npm run fix:prettier",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier -w .",
    "lint:ci": "npm run check:eslint -- --output-file eslint-report.json --format json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --reporter=default --reporter=junit --outputFile=junit.xml --coverage.enabled --coverage.reporter=lcov --coverage.reporter=text"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/quicksand": "^5.2.10",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.2",
    "astro-icon": "^1.1.5",
    "limax": "4.2.3",
    "lodash.merge": "^4.6.2",
    "unpic": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^6.0.1",
    "@astrojs/partytown": "^2.1.7",
    "@eslint/js": "^10.0.1",
    "@iconify-json/flat-color-icons": "^1.2.3",
    "@iconify-json/tabler": "^1.2.35",
    "@tailwindcss/typography": "^0.5.19",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.merge": "^4.6.9",
    "@types/mdx": "^2.0.14",
    "@vitest/coverage-v8": "^4.1.8",
    "astro-compress": "^2.4.1",
    "astro-eslint-parser": "^1.4.0",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "js-yaml": "^4.2.0",
    "mdast-util-to-string": "^4.0.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "reading-time": "^1.5.0",
    "sharp": "0.34.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "unist-util-visit": "^5.1.0",
    "vitest": "^4.1.5"
  }
}
